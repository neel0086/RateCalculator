{
  "name": "rate_calculator",
  "version": "0.1.0",
  "private": true,
  "description": "Smart Rate Calculator desktop app",
  "author": "Shree Vallabh Packaging",
  "homepage": "./",
  "main": "public/electron.js",
  "proxy": "https://leetcode.com",
  "dependencies": {
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "@headlessui/react": "^1.7.13",
    "@tailwindui/react": "^0.1.1",
    "@testing-library/jest-dom": "^5.11.4",
    "@testing-library/react": "^11.1.0",
    "@testing-library/user-event": "^12.1.10",
    "concurrently": "^7.6.0",
    "cross-env": "^7.0.3",
    "dotenv": "^10.0.0",
    "electron": "^22.3.27",
    "electron-builder": "^23.6.0",
    "electron-packager": "^17.1.1",
    "electron-store": "^8.1.0",
    "export-from-json": "^1.7.2",
    "react": "^17.0.2",
    "react-ace": "^9.5.0",
    "react-color": "^2.19.3",
    "react-dom": "^17.0.2",
    "react-icons": "^4.8.0",
    "react-router-dom": "^6.10.0",
    "react-scripts": "^5.0.1",
    "sass": "^1.89.2",
    "tailwindcss": "^3.3.0",
    "uuid": "^8.3.2",
    "wait-on": "^6.0.1",
    "web-vitals": "^1.0.1",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "react-test": "react-scripts test",
    "react-eject": "react-scripts eject",
    "electron-build": "electron-builder",
    "build": "npm run react-build && npm run electron-build",
    "build:installer": "powershell -ExecutionPolicy Bypass -File scripts/build-installer.ps1",
    "start": "concurrently \"cross-env BROWSER=none npm run react-start\" \"wait-on http://localhost:3000 && electron .\""
  },
  "build": {
    "appId": "com.shreevallabh.smart-rate-calculator",
    "productName": "Rate Calculator - svp2",
    "copyright": "Copyright (c) 2026 Shree Vallabh Packaging",
    "asar": true,
    "compression": "normal",
    "afterPack": "scripts/after-pack.js",
    "removePackageScripts": true,
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "public/electron.js",
      "package.json",
      "node_modules/electron-is-dev/**/*",
      "!**/*.map",
      "!**/.cache/**/*",
      "!**/test{,s}/**/*",
      "!**/__tests__/**/*",
      "!**/*.md"
    ],
    "extraMetadata": {
      "main": "public/electron.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/logo512.png",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Smart Rate Calculator",
      "deleteAppDataOnUninstall": false
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
